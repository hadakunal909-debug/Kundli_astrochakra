# Supabase — server-side credentials for persisting birth inputs.
# Copy this file to `web/.env.local` and fill in your project's values.
# (.env.local is gitignored — never commit real keys.)
#
# Find these in the Supabase dashboard → Project Settings → API:
#   SUPABASE_URL              → "Project URL"
#   SUPABASE_SERVICE_ROLE_KEY → "Project API keys" → service_role (secret)
#
# IMPORTANT: use the service_role key, NOT the anon key. It is read only on the
# server (no NEXT_PUBLIC_ prefix), so it is never sent to the browser. If these
# vars are absent, the app still works — it just skips saving.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
